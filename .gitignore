!data/processed/.gitkeep

# Logs
logs/*
*.log
!logs/.gitkeep

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Jupyter
.ipynb_checkpoints/

# ML Models (large binary files) — ignore root-level models/ only, not app/models/
/models/
*.bin
*.pt
*.pth
*.onnx

# HuggingFace cache
.cache/

# Temporary files
tmp/
temp/
*.tmp

# Vercel
.vercel/
.vercel
