# ─────────────────────────────────────────────────────────────────────────────
# Automated Research Assistant — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# Application
APP_NAME=Research Assistant
APP_VERSION=1.0.0
DEBUG=False
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000

# ── Groq LLM (https://console.groq.com) ──────────────────────────────────────
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TEMPERATURE=0.3
GROQ_MAX_TOKENS=2048

# ── Qdrant Cloud (https://cloud.qdrant.io) ────────────────────────────────────
QDRANT_URL=https://your-cluster-id.region.gcp.cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here
QDRANT_COLLECTION=research_papers

# ── Embeddings (local sentence-transformers, no API key needed) ───────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
EMBEDDING_BATCH_SIZE=32

# ── Document Processing ───────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=50
CHUNK_SIZE=512
CHUNK_OVERLAP=50
MIN_CHUNK_LENGTH=100

# ── Retrieval ─────────────────────────────────────────────────────────────────
DEFAULT_TOP_K=5
HYBRID_SEARCH_WEIGHT=0.5
MIN_SIMILARITY_SCORE=0.3

# ── Agent ─────────────────────────────────────────────────────────────────────
AGENT_MAX_ITERATIONS=5
AGENT_VERBOSE=False

# ── Storage ───────────────────────────────────────────────────────────────────
UPLOAD_DIR=data/uploads
PROCESSED_DIR=data/processed
LOG_DIR=logs
